{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cargo fmt --all && cargo clippy --all-targets --all-features || true",
            "timeout": 600,
            "statusMessage": "Running cargo fmt and clippy"
          }
        ]
      }
    ]
  }
}
